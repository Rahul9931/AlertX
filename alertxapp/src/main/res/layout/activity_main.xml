<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="AlertX Sheet Demo"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Featured Morph Animation -->
            <Button
                android:id="@+id/btn_sheet_morph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:backgroundTint="#673AB7"
                android:text="Sheet: Morph (Top - Featured)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:backgroundTint="#4CAF50"
                android:text="Sheet: Success (Top - Slide)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:backgroundTint="#2196F3"
                android:text="Sheet: Info (Bottom - Bounce)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_warn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:backgroundTint="#FFEB3B"
                android:text="Sheet: Warning (Top - Slide Left)"
                android:textColor="#000000"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:backgroundTint="#F44336"
                android:text="Sheet: Error (Bottom - Slide Right)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_zoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="Sheet: Zoom Animation (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_fade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="Sheet: Fade Animation (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_left_bounce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="Sheet: Left Bounce (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_right_bounce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                android:text="Sheet: Right Bounce (Bottom)"
                android:textAllCaps="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>