<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- AlertX Sheet Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="AlertX Sheet Demo"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_sheet_morph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#673AB7"
                android:text="Sheet: Morph (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#4CAF50"
                android:text="Sheet: Success (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#2196F3"
                android:text="Sheet: Info (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_warn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#FFEB3B"
                android:text="Sheet: Warning (Top)"
                android:textColor="#000000"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#F44336"
                android:text="Sheet: Error (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_zoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Sheet: Zoom (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_fade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Sheet: Fade (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_left_bounce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Sheet: Left Bounce (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_sheet_right_bounce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Sheet: Right Bounce (Bottom)"
                android:textAllCaps="false" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginVertical="24dp"
                android:background="#DDDDDD" />

            <!-- AlertX Toast Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="AlertX Toast Demo"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_toast_morph"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#673AB7"
                android:text="Toast: Morph (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#4CAF50"
                android:text="Toast: Success (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#2196F3"
                android:text="Toast: Info (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_warn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#FFEB3B"
                android:text="Toast: Warning (Top)"
                android:textColor="#000000"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:backgroundTint="#F44336"
                android:text="Toast: Error (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_zoom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Toast: Zoom (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_fade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Toast: Fade (Bottom)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_left_bounce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Toast: Left Bounce (Top)"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_toast_right_bounce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="4dp"
                android:text="Toast: Right Bounce (Bottom)"
                android:textAllCaps="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>